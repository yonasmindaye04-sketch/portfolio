# ─── EthioDigital Backend — Environment Variables ──────────────
# Copy this file to .env (in the server/ folder) and fill in your values.
# NEVER commit .env to git.

# Your Gmail address
EMAIL=yonasmindaye04@gmail.com

# Gmail APP PASSWORD (NOT your login password)
# Steps to generate one:
#   1. Go to your Google Account → Security
#   2. Enable 2-Step Verification (required)
#   3. Visit https://myaccount.google.com/apppasswords
#   4. Select app = "Mail", device = "Other" → enter "EthioDigital"
#   5. Copy the 16-character password (remove spaces) and paste below
EMAIL_PASS= qobl pcwh pfjd cbdl

# Optional — change the port the server listens on (default: 5000)
# PORT=5000


